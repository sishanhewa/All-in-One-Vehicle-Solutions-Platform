          }
        },
        {
          "name": "3.4 Browse Companies (search)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/inspection/companies?search=Auto",
              "host": ["{{base_url}}"],
              "path": ["api", "inspection", "companies"],
              "query": [{ "key": "search", "value": "Auto" }]
            }
          }
        },
        {
          "name": "3.5 Get Company by ID (with packages)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/inspection/companies/{{company_id}}", "host": ["{{base_url}}"], "path": ["api", "inspection", "companies", "{{company_id}}"] }
          }
        },
        {
          "name": "3.6 Get Own Company Profile 🔒",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{company_token}}" }],
            "url": { "raw": "{{base_url}}/api/inspection/companies/profile", "host": ["{{base_url}}"], "path": ["api", "inspection", "companies", "profile"] }
          }
        },
        {
          "name": "3.7 Update Company Profile 🔒",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{company_token}}" }],
            "url": { "raw": "{{base_url}}/api/inspection/companies/profile", "host": ["{{base_url}}"], "path": ["api", "inspection", "companies", "profile"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "companyName", "value": "Updated Company Name", "type": "text" },
                { "key": "description", "value": "Updated description for the company", "type": "text" },
                { "key": "operatingHours", "value": "Mon-Sun 7:00 AM - 7:00 PM", "type": "text" },
                { "key": "logo", "type": "file", "src": "" }
