    {
      "name": "5. Inspection — Booking (User Side)",
      "description": "User-facing booking operations",
      "item": [
        {
          "name": "5.1 Create Booking 🔒 User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/inspection/bookings", "host": ["{{base_url}}"], "path": ["api", "inspection", "bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyId\": \"{{company_id}}\",\n  \"packageId\": \"{{package_id}}\",\n  \"make\": \"Toyota\",\n  \"model\": \"Corolla\",\n  \"year\": 2021,\n  \"plateNumber\": \"CAB-1234\",\n  \"vehicleType\": \"Car\",\n  \"appointmentDate\": \"2026-04-15\",\n  \"appointmentTime\": \"10:00 AM\",\n  \"notes\": \"Please also check the AC system\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = res.getBody();",
                "if (jsonData._id) {",
                "  bru.setVar('booking_id', jsonData._id);",
                "  console.log('✅ booking_id saved');",
                "}"
              ]
            }
          }]
        },
        {
          "name": "5.2 Get My Bookings 🔒 User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/api/inspection/bookings/my-bookings", "host": ["{{base_url}}"], "path": ["api", "inspection", "bookings", "my-bookings"] }
          }
        },
        {
          "name": "5.3 Get My Bookings (filter by status) 🔒",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/inspection/bookings/my-bookings?status=Pending",
              "host": ["{{base_url}}"],
              "path": ["api", "inspection", "bookings", "my-bookings"],
              "query": [{ "key": "status", "value": "Pending" }]
            }
          }
        },
        {
          "name": "5.4 Get Booking Details 🔒",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/api/inspection/bookings/{{booking_id}}", "host": ["{{base_url}}"], "path": ["api", "inspection", "bookings", "{{booking_id}}"] }
          }
        },
        {
          "name": "5.5 Cancel Booking 🔒 User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/inspection/bookings/{{booking_id}}/cancel", "host": ["{{base_url}}"], "path": ["api", "inspection", "bookings", "{{booking_id}}", "cancel"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Schedule conflict — need to reschedule\"\n}"
            }
          }
        }
      ]
    },
    {
