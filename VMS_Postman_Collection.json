            "body": {
              "mode": "raw",
              "raw": "{\n  \"inspectionResult\": \"Pass\",\n  \"overallScore\": 87,\n  \"checklist\": [\n    { \"item\": \"Engine\", \"condition\": \"Good\", \"notes\": \"Running smoothly, no unusual sounds\" },\n    { \"item\": \"Transmission\", \"condition\": \"Excellent\", \"notes\": \"Smooth gear shifts\" },\n    { \"item\": \"Brakes\", \"condition\": \"Fair\", \"notes\": \"Front pads worn ~60%, replacement recommended within 10,000km\" },\n    { \"item\": \"Suspension\", \"condition\": \"Good\", \"notes\": \"No leaks or unusual movement\" },\n    { \"item\": \"Electrical\", \"condition\": \"Excellent\", \"notes\": \"All systems functional\" },\n    { \"item\": \"Body\", \"condition\": \"Good\", \"notes\": \"Minor scratch on rear bumper\" },\n    { \"item\": \"Interior\", \"condition\": \"Good\", \"notes\": \"Clean, all controls working\" },\n    { \"item\": \"Tires\", \"condition\": \"Excellent\", \"notes\": \"New tires, ~95% tread remaining\" }\n  ],\n  \"resultRemarks\": \"Vehicle is in good overall condition. Recommended: Replace front brake pads within 10,000km. Minor cosmetic scratch on rear bumper. All major systems are functioning properly.\"\n}"
            }
          }
        },
