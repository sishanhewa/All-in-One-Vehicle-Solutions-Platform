          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{company_token}}" }],
            "url": { "raw": "{{base_url}}/api/inspection/bookings/{{booking_id}}/images", "host": ["{{base_url}}"], "path": ["api", "inspection", "bookings", "{{booking_id}}", "images"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "reportImages", "type": "file", "src": "" },
                { "key": "reportImages", "type": "file", "src": "" }
              ]
            }
          }
        },
