{
  "info": {
    "name": "Vehicle Management System — Complete API Collection",
    "description": "Full API collection for the Vehicle Management System including Auth, Marketplace, and Vehicle Inspection modules.\n\n## Setup\n1. Set `base_url` variable to `http://localhost:5000`\n2. Register a user and copy the token to `user_token`\n3. Register a company and copy the token to `company_token`\n\n## Testing Workflow\n1. Auth → Register & Login\n2. Marketplace → CRUD listings\n3. Inspection → Register company → Create packages → Book → Confirm → Start → Complete\n\nFor detailed request/response examples, refer to `API_TESTING_GUIDE.md`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000" },
    { "key": "user_token", "value": "" },
    { "key": "company_token", "value": "" },
    { "key": "listing_id", "value": "" },
    { "key": "company_id", "value": "" },
    { "key": "package_id", "value": "" },
    { "key": "booking_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "description": "User authentication endpoints",
      "item": [
        {
          "name": "1.1 Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Buyer\",\n  \"email\": \"buyer@test.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+94771234567\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = res.getBody();",
                "if (jsonData.token) {",
                "  bru.setVar('user_token', jsonData.token);",
                "  console.log('✅ user_token saved');",
                "}"
              ]
            }
          }]
        },
        {
          "name": "1.2 Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@test.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = res.getBody();",
                "if (jsonData.token) {",
                "  bru.setVar('user_token', jsonData.token);",
                "  console.log('✅ user_token saved');",
                "}"
              ]
            }
          }]
        },
        {
          "name": "1.3 Login as Company (Ceylon AutoCare)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"info@ceylonautocare.lk\",\n  \"password\": \"ceylon123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = res.getBody();",
                "if (jsonData.token) {",
                "  bru.setVar('company_token', jsonData.token);",
                "  bru.setVar('company_id', jsonData._id);",
                "  console.log('✅ company_token & company_id saved');",
                "}"
              ]
            }
          }]
        },
        {
          "name": "1.4 Get User Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/profile", "host": ["{{base_url}}"], "path": ["api", "auth", "profile"] }
          }
        }
      ]
    },
    {
      "name": "2. Marketplace",
      "description": "Vehicle listing CRUD endpoints",
      "item": [
        {
          "name": "2.1 Get All Listings",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/marketplace", "host": ["{{base_url}}"], "path": ["api", "marketplace"] }
          }
        },
        {
          "name": "2.2 Get All Listings (with filters)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/marketplace?make=Toyota&minPrice=500000&maxPrice=5000000&location=Colombo",
              "host": ["{{base_url}}"],
              "path": ["api", "marketplace"],
              "query": [
                { "key": "make", "value": "Toyota" },
                { "key": "minPrice", "value": "500000" },
                { "key": "maxPrice", "value": "5000000" },
                { "key": "location", "value": "Colombo" }
              ]
            }
          }
        },
        {
          "name": "2.3 Get Single Listing",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/marketplace/{{listing_id}}", "host": ["{{base_url}}"], "path": ["api", "marketplace", "{{listing_id}}"] }
          }
        },
        {
          "name": "2.4 Create Listing",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/api/marketplace", "host": ["{{base_url}}"], "path": ["api", "marketplace"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "2023 Toyota Aqua for Sale", "type": "text" },
                { "key": "make", "value": "Toyota", "type": "text" },
                { "key": "model", "value": "Aqua", "type": "text" },
                { "key": "year", "value": "2023", "type": "text" },
                { "key": "price", "value": "8500000", "type": "text" },
                { "key": "mileage", "value": "25000", "type": "text" },
                { "key": "fuelType", "value": "Hybrid", "type": "text" },
                { "key": "transmission", "value": "Automatic", "type": "text" },
                { "key": "bodyType", "value": "Hatchback", "type": "text" },
                { "key": "location", "value": "Colombo", "type": "text" },
                { "key": "condition", "value": "Reconditioned", "type": "text" },
                { "key": "description", "value": "Single owner, mint condition. Low mileage.", "type": "text" },
                { "key": "images", "type": "file", "src": "" }
              ]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = res.getBody();",
                "if (jsonData._id) {",
                "  bru.setVar('listing_id', jsonData._id);",
                "  console.log('✅ listing_id saved');",
                "}"
              ]
            }
          }]
        },
        {
          "name": "2.5 Update Listing",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/api/marketplace/{{listing_id}}", "host": ["{{base_url}}"], "path": ["api", "marketplace", "{{listing_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 7900000,\n  \"description\": \"Price reduced! Single owner, excellent condition.\"\n}"
            }
          }
        },
        {
          "name": "2.6 Delete Listing",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/api/marketplace/{{listing_id}}", "host": ["{{base_url}}"], "path": ["api", "marketplace", "{{listing_id}}"] }
          }
        },
        {
          "name": "2.7 Get My Listings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": { "raw": "{{base_url}}/api/marketplace/my-listings", "host": ["{{base_url}}"], "path": ["api", "marketplace", "my-listings"] }
          }
        }
      ]
    },
    {
      "name": "3. Inspection — Company Management",
      "description": "Inspection company registration and profile management",
      "item": [
        {
          "name": "3.1 Register Inspection Company",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/inspection/companies/register", "host": ["{{base_url}}"], "path": ["api", "inspection", "companies", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Inspector\",\n  \"email\": \"newinspector@test.lk\",\n  \"password\": \"password123\",\n  \"phone\": \"+94771112233\",\n  \"companyName\": \"New Test Inspections\",\n  \"description\": \"Professional vehicle inspection services\",\n  \"address\": \"No. 100, Main Street\",\n  \"city\": \"Colombo\",\n  \"operatingHours\": \"Mon-Sat 8:00 AM - 6:00 PM\",\n  \"website\": \"https://newtestinspect.lk\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = res.getBody();",
                "if (jsonData.token) {",
                "  bru.setVar('company_token', jsonData.token);",
                "  bru.setVar('company_id', jsonData._id);",
                "  console.log('✅ company_token & company_id saved');",
                "}"
              ]
            }
          }]
        },
        {
          "name": "3.2 Browse All Companies",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/inspection/companies", "host": ["{{base_url}}"], "path": ["api", "inspection", "companies"] }
          }
        },
        {
          "name": "3.3 Browse Companies (filter by city)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/inspection/companies?city=Colombo",
              "host": ["{{base_url}}"],
              "path": ["api", "inspection", "companies"],
              "query": [{ "key": "city", "value": "Colombo" }]
