          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/inspection/companies/{{company_id}}/packages", "host": ["{{base_url}}"], "path": ["api", "inspection", "companies", "{{company_id}}", "packages"] }
          }
        }
      ]
    },
